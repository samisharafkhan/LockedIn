# Copy to `.env.local` for Vite. Required for Google sign-in (Firebase Auth).
# From Firebase console → Project settings → Your apps → Web app config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Web OAuth 2.0 client ID (Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client IDs).
# Use the same “Web client” as Firebase; authorized origins must include this app’s URL (e.g. http://localhost:5173).
# Needed for Google Calendar API from the browser (separate from Firebase ID tokens).
VITE_GOOGLE_OAUTH_CLIENT_ID=
